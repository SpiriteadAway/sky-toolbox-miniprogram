/* ====== 光翼查询页 ====== */

/* 输入区 */
.query-card {
  margin-bottom: 20rpx;
}

.query-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #9ca3af;
  margin-bottom: 12rpx;
}

.input-row {
  display: flex;
  align-items: center;
  background: #f4f5f7;
  border-radius: 12rpx;
  padding: 0 16rpx;
  margin-bottom: 20rpx;
}

.input-icon { font-size: 28rpx; margin-right: 10rpx; }

.query-input {
  flex: 1;
  height: 84rpx;
  font-size: 28rpx;
  color: #1e1b4b;
}

.input-clear {
  width: 32rpx; height: 32rpx;
  border-radius: 50%;
  background: #d4d4d8;
  display: flex; align-items: center; justify-content: center;
  font-size: 20rpx; color: #fff;
}

.query-btn {
  width: 100%; height: 84rpx; line-height: 84rpx;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff; font-size: 30rpx; font-weight: 600;
  border-radius: 12rpx; border: none; letter-spacing: 2rpx;
  box-shadow: 0 4rpx 16rpx rgba(99,102,241,0.2);
}

.query-btn[disabled] {
  background: #e5e7eb; color: #9ca3af; box-shadow: none;
}

/* 加载 */
.loading-bar {
  display: flex; align-items: center; justify-content: center;
  padding: 40rpx 0; gap: 12rpx;
}

.loading-dot {
  width: 14rpx; height: 14rpx; border-radius: 50%;
  background: #6366f1;
  animation: ldPulse 1.2s ease-in-out infinite;
}

.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes ldPulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.3; }
  40% { transform: scale(1); opacity: 1; }
}

.loading-text {
  font-size: 24rpx; color: #9ca3af; margin-left: 8rpx;
}

/* ====== 总览双卡 ====== */
.overview-row {
  display: flex; gap: 14rpx; margin-bottom: 24rpx;
}

.overview-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 18rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  display: flex; flex-direction: column; align-items: center;
  position: relative;
  overflow: hidden;
}

.overview-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0;
  height: 6rpx;
}

.oc-normal::before { background: linear-gradient(90deg, #10b981, #34d399); }
.oc-perm::before   { background: linear-gradient(90deg, #8b5cf6, #a78bfa); }

.oc-emoji { font-size: 32rpx; margin: 8rpx 0 4rpx; }
.oc-label { font-size: 22rpx; color: #9ca3af; margin-bottom: 12rpx; }

.oc-stat {
  display: flex; align-items: baseline; margin-bottom: 12rpx;
}

.oc-cur { font-size: 48rpx; font-weight: 800; color: #1e1b4b; line-height: 1; }
.oc-div { font-size: 28rpx; color: #d4d4d8; margin: 0 4rpx; }
.oc-tot { font-size: 28rpx; color: #d4d4d8; }

.oc-bar {
  width: 100%; height: 8rpx;
  background: #f4f5f7; border-radius: 4rpx;
  overflow: hidden; margin-bottom: 10rpx;
}

.oc-normal .oc-bar-fill {
  height: 100%; background: linear-gradient(90deg, #10b981, #34d399);
  border-radius: 4rpx; transition: width 0.6s ease;
}

.oc-perm .oc-bar-fill {
  height: 100%; background: linear-gradient(90deg, #8b5cf6, #a78bfa);
  border-radius: 4rpx; transition: width 0.6s ease;
}

.oc-pct { font-size: 26rpx; font-weight: 700; }
.oc-normal .oc-pct { color: #10b981; }
.oc-perm .oc-pct   { color: #8b5cf6; }

/* ====== Section 标题 ====== */
.section-title {
  font-size: 26rpx; font-weight: 600;
  color: #1e1b4b; padding: 4rpx 0 16rpx;
  display: flex; align-items: center; gap: 8rpx;
}

.st-dot {
  width: 8rpx; height: 8rpx; border-radius: 50%; flex-shrink: 0;
}

.st-dot.green  { background: #10b981; }
.st-dot.purple { background: #8b5cf6; }
.st-dot.gold   { background: #f59e0b; }

.st-count {
  font-size: 22rpx; color: #9ca3af; margin-left: auto; font-weight: 400;
}

/* ====== 地图网格（两列） ====== */
.map-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.map-card {
  box-sizing: border-box;
  width: 49%;
  background: #fff;
  border-radius: 14rpx;
  padding: 20rpx 16rpx 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
  transition: all 0.15s;
  margin-bottom: 14rpx;
}

.map-card-last {
  width: 100%;
}

.map-card:active { transform: scale(0.97); }

.map-card-top {
  display: flex; align-items: center; margin-bottom: 12rpx; gap: 8rpx;
}

.map-card-emoji { font-size: 28rpx; flex-shrink: 0; }

.map-card-info { flex: 1; min-width: 0; }

.map-card-name {
  font-size: 24rpx; font-weight: 600; color: #1e1b4b;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block;
}

.map-card-stat {
  font-size: 20rpx; color: #9ca3af; margin-top: 2rpx;
}

.map-card-pct {
  font-size: 26rpx; font-weight: 700; color: #6366f1; flex-shrink: 0;
}

.map-card-pct.done { color: #10b981; }

.map-card-bar {
  height: 6rpx; background: #f4f5f7; border-radius: 3rpx; overflow: hidden;
}

.map-card-fill {
  height: 100%;
  background: linear-gradient(90deg, #818cf8, #6366f1);
  border-radius: 3rpx; transition: width 0.6s ease;
}

.map-card-fill.done { background: linear-gradient(90deg, #34d399, #10b981); }

/* 永久光翼单行卡片 */
.perm-row {
  display: flex; gap: 14rpx; margin-bottom: 8rpx;
}

.perm-card {
  flex: 1;
  background: #fff;
  border-radius: 14rpx;
  padding: 20rpx 16rpx 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
}

.perm-card-top {
  display: flex; align-items: center; margin-bottom: 12rpx; gap: 8rpx;
}

.perm-card-emoji { font-size: 28rpx; flex-shrink: 0; }

.perm-card-info { flex: 1; min-width: 0; }

.perm-card-name {
  font-size: 24rpx; font-weight: 600; color: #1e1b4b;
}

.perm-card-desc {
  font-size: 20rpx; color: #9ca3af; margin-top: 2rpx;
}

.perm-card-pct {
  font-size: 26rpx; font-weight: 700; color: #8b5cf6; flex-shrink: 0;
}

.perm-card-pct.done { color: #10b981; }

.perm-card-bar {
  height: 6rpx; background: #f4f5f7; border-radius: 3rpx; overflow: hidden;
}

.perm-card-fill {
  height: 100%;
  background: linear-gradient(90deg, #a78bfa, #8b5cf6);
  border-radius: 3rpx; transition: width 0.6s ease;
}

.perm-card-fill.done { background: linear-gradient(90deg, #34d399, #10b981); }

.perm-travel .perm-card-fill {
  background: linear-gradient(90deg, #fbbf24, #f59e0b);
}

.perm-travel .perm-card-pct { color: #f59e0b; }

/* ====== 未收集标签 ====== */
.missing-wrap {
  display: flex; flex-wrap: wrap; gap: 10rpx; margin-bottom: 24rpx;
}

.missing-tag {
  display: flex; align-items: center;
  background: #fffbeb;
  border: 1rpx solid #fde68a;
  border-radius: 20rpx;
  padding: 8rpx 16rpx;
  gap: 6rpx;
  font-size: 22rpx;
  color: #92400e;
}

.missing-tag-emoji { font-size: 22rpx; }

.missing-tag-count {
  background: #fef3c7;
  border-radius: 10rpx;
  padding: 2rpx 10rpx;
  font-size: 20rpx;
  color: #b45309;
  margin-left: 4rpx;
}

/* 动画 */
.fade-in { animation: fadeIn 0.4s ease both; }

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
