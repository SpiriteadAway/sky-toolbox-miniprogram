/* ====== 季节倒计时页 ====== */

/* 主倒计时 Hero */
.countdown-hero {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #a78bfa 100%);
  border-radius: 20rpx;
  padding: 48rpx 30rpx;
  text-align: center;
  margin-bottom: 20rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 30rpx rgba(99,102,241,0.2);
}

.cd-glow {
  position: absolute;
  top: -40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 260rpx;
  height: 260rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.cd-number {
  font-size: 88rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
  position: relative;
  z-index: 1;
}

.cd-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 8rpx;
  position: relative;
  z-index: 1;
}

/* 描述卡片 */
.desc-label {
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.6;
}

/* 进度网格 */
.progress-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.progress-item {
  width: calc(50% - 7rpx);
  background: #f8f7ff;
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  text-align: center;
  box-sizing: border-box;
}

.pi-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.pi-label {
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 6rpx;
}

.pi-value {
  font-size: 26rpx;
  font-weight: 700;
  color: #6366f1;
}

.progress-item-wide {
  background: #f0fdf4;
  border-radius: 12rpx;
  padding: 20rpx 20rpx;
  text-align: center;
}
