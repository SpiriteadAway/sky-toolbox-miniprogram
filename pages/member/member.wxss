/* ====== 会员中心页 ====== */

/* 会员信息卡片 */
.vip-info-card {
  background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(30, 27, 75, 0.15);
}

.vic-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.vic-level-badge {
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}

.vic-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  padding: 16rpx 0;
}

.vic-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.vic-stat-num {
  font-size: 48rpx;
  font-weight: 800;
}

.vic-stat-num.has {
  color: #a5f3fc;
}

.vic-stat-num.empty {
  color: #fca5a5;
}

.vic-stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  margin-top: 4rpx;
}

.vic-stat-div {
  width: 2rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.15);
}

.vic-action {
  display: block;
  text-align: center;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  margin-top: 8rpx;
}

/* 说明卡片 */
.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-top: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.info-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #9ca3af;
  padding-bottom: 12rpx;
}

.info-item {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 2;
  padding-left: 4rpx;
}

/* ====== 客服联系卡片 ====== */
.contact-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #fef2f2 0%, #fff7ed 100%);
  border: 2rpx solid #fecaca;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}

.contact-card.contact-has-credit {
  background: linear-gradient(135deg, #f0f9ff 0%, #faf5ff 100%);
  border-color: #c7d2fe;
}

.contact-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.contact-body {
  flex: 1;
}

.contact-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e1b4b;
  margin-bottom: 4rpx;
}

.contact-desc {
  font-size: 24rpx;
  color: #9ca3af;
}

.contact-btn {
  flex-shrink: 0;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  background: linear-gradient(135deg, #ef4444, #f97316);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 32rpx;
  border: none;
}

.contact-btn-outline {
  background: #fff;
  color: #6366f1;
  border: 2rpx solid #c7d2fe;
}
