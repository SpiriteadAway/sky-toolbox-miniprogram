/* ====== 礼包查询页 ====== */

.query-card { margin-bottom: 20rpx; }
.query-label { font-size: 24rpx; font-weight: 600; color: #9ca3af; margin-bottom: 12rpx; }
.input-row {
  display: flex; align-items: center; background: #f4f5f7;
  border-radius: 12rpx; padding: 0 16rpx; margin-bottom: 20rpx;
}
.code-input { flex: 1; height: 84rpx; font-size: 30rpx; color: #1e1b4b; }
.clear-btn {
  width: 32rpx; height: 32rpx; display: flex; align-items: center;
  justify-content: center; background: #d4d4d8; border-radius: 50%;
  flex-shrink: 0; font-size: 20rpx; color: #fff; line-height: 1;
}

/* 概览 */
.gift-summary { margin-bottom: 20rpx; }
.gs-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12rpx; }
.gs-label { font-size: 26rpx; color: #059669; font-weight: 500; }
.gs-time { font-size: 20rpx; color: #bbb; }
.gs-stats { display: flex; gap: 16rpx; }
.gs-stat { flex: 1; background: #f9fafb; border-radius: 12rpx; padding: 14rpx; text-align: center; }
.gs-stat-val { font-size: 32rpx; font-weight: 800; color: #1e1b4b; display: block; }
.gs-stat-val.price { color: #ef4444; }
.gs-stat-lbl { font-size: 20rpx; color: #9ca3af; }

/* 礼包卡片 */
.gift-list { margin-bottom: 20rpx; }
.gift-card {
  background: #fff; border-radius: 14rpx; margin-bottom: 14rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04); overflow: hidden;
}
.gc-header {
  display: flex; align-items: center; padding: 18rpx 18rpx;
}
.gc-thumb {
  width: 100rpx; height: 100rpx; border-radius: 10rpx;
  background: #f9fafb; flex-shrink: 0;
}
.gc-info { flex: 1; margin-left: 16rpx; min-width: 0; }
.gc-name {
  font-size: 26rpx; font-weight: 700; color: #1e1b4b;
  margin-bottom: 4rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.gc-meta { display: flex; align-items: center; gap: 8rpx; flex-wrap: wrap; }
.gc-price { font-size: 24rpx; font-weight: 700; color: #ef4444; }
.gc-badge {
  font-size: 18rpx; padding: 2rpx 10rpx; border-radius: 8rpx;
  background: #f0fdf4; color: #166534;
}
.gc-badge.collab { background: #fef3c7; color: #92400e; }
.gc-badge.type { background: #ede9fe; color: #6d28d9; }
.gc-source { font-size: 22rpx; color: #9ca3af; margin-top: 4rpx; }
.gc-arrow {
  font-size: 20rpx; color: #d4d4d8; flex-shrink: 0; margin-left: 8rpx;
  transition: transform 0.2s;
}
.gc-arrow.open { transform: rotate(180deg); }

/* 展开详情 */
.gc-detail {
  border-top: 1rpx solid #f4f5f7;
  padding: 16rpx 18rpx;
  background: #fafafa;
  animation: fadeIn 0.2s ease-out;
}
.gcd-section { margin-bottom: 16rpx; }
.gcd-section:last-child { margin-bottom: 0; }
.gcd-row {
  display: flex; align-items: center; padding: 6rpx 0;
  font-size: 24rpx;
}
.gcd-key { color: #9ca3af; width: 80rpx; flex-shrink: 0; }
.gcd-val { color: #1e1b4b; font-weight: 500; }
.gcd-val.price { color: #ef4444; font-weight: 700; }
.gcd-title { font-size: 24rpx; font-weight: 600; color: #6b7280; margin-bottom: 10rpx; }

.gcd-images { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10rpx; }
.gcd-img-item { background: #fff; border-radius: 10rpx; overflow: hidden; }
.gcd-img-item:active { opacity: 0.8; }
.gcd-img { width: 100%; display: block; }
.gcd-img-name {
  display: block; font-size: 18rpx; color: #9ca3af; text-align: center;
  padding: 6rpx 4rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-6rpx); }
  to { opacity: 1; transform: translateY(0); }
}
